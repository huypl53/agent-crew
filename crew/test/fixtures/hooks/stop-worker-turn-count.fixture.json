{
  "name": "stop-worker-turn-count-increments",
  "description": "Each worker Stop increments goal turn_count",
  "seed": {
    "room": {
      "name": "dev",
      "path": "/tmp/test-crew"
    },
    "agents": [
      {
        "name": "w1",
        "pane": "%42",
        "role": "worker"
      }
    ],
    "goals": [
      {
        "agent": "w1",
        "description": "Track turns"
      }
    ]
  },
  "steps": [
    {
      "event": "Stop",
      "pane": "%42",
      "expect": {
        "tmux": [
          {
            "op": "sendKeys",
            "target": "%42",
            "contains": "(turn 1)"
          }
        ]
      }
    },
    {
      "event": "Stop",
      "pane": "%42",
      "expect": {
        "tmux": [
          {
            "op": "sendKeys",
            "target": "%42",
            "contains": "(turn 2)"
          }
        ]
      }
    },
    {
      "event": "Stop",
      "pane": "%42",
      "expect": {
        "tmux": [
          {
            "op": "sendKeys",
            "target": "%42",
            "contains": "(turn 3)"
          }
        ]
      }
    }
  ]
}
