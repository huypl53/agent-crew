{
  "name": "permission-then-stop-session-only",
  "description": "No-pane PermissionRequest followed by no-pane Stop on the same session persists both events without worker tmux delivery",
  "seed": {
    "room": { "name": "codex-flow", "path": "/tmp/permission-stop-room" },
    "agents": [
      { "name": "worker-1", "pane": "%72", "role": "worker" }
    ]
  },
  "steps": [
    {
      "event": "PermissionRequest",
      "pane": null,
      "payload": {
        "session_id": "chain-session-1",
        "cwd": "/tmp/permission-stop-room/tasks/1",
        "tool_name": "Bash"
      },
      "expect": {
        "stdout_path": [
          { "path": "hookSpecificOutput.hookEventName", "value": "PermissionRequest" },
          { "path": "hookSpecificOutput.decision.behavior", "value": "allow" }
        ],
        "hook_event": {
          "agent": "worker-1",
          "event": "PermissionRequest",
          "session_id": "chain-session-1"
        },
        "hook_events_count": 1
      }
    },
    {
      "event": "Stop",
      "pane": null,
      "payload": {
        "session_id": "chain-session-1",
        "cwd": "/tmp/permission-stop-room/tasks/1"
      },
      "expect": {
        "stdout": { "ok": true, "decision": "allow" },
        "hook_event": {
          "agent": "worker-1",
          "event": "Stop",
          "session_id": "chain-session-1"
        },
        "hook_events_count": 2,
        "tmux_absent": [
          { "op": "sendKeys", "target": "%72" }
        ]
      }
    }
  ]
}
