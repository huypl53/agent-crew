{
  "name": "stop-done-goal-no-reminder",
  "description": "Agent with completed goal does not receive reminder on Stop",
  "seed": {
    "room": { "name": "dev", "path": "/tmp/done-goal" },
    "agents": [{ "name": "w1", "pane": "%42", "role": "worker" }],
    "goals": [
      {
        "agent": "w1",
        "description": "Already finished task",
        "status": "done"
      }
    ]
  },
  "steps": [
    {
      "event": "Stop",
      "pane": "%42",
      "expect": {
        "stdout": { "ok": true, "decision": "allow" },
        "tmux_absent": [{ "op": "sendKeys", "target": "%42" }]
      }
    }
  ]
}
