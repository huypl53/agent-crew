{
  "name": "user-prompt-submit-hint-cadence",
  "description": "Hint fires on cadence (every 3rd UserPromptSubmit)",
  "seed": {
    "room": {
      "name": "dev",
      "path": "/tmp/test-crew"
    },
    "agents": [
      {
        "name": "w1",
        "pane": "%42",
        "role": "worker"
      }
    ],
    "hints": [
      {
        "agent": "w1",
        "message": "Remember: use TypeScript strict mode",
        "cadence": 3
      }
    ]
  },
  "steps": [
    {
      "event": "UserPromptSubmit",
      "pane": "%42",
      "expect": {
        "stdout": {
          "ok": true,
          "decision": "allow"
        }
      }
    },
    {
      "event": "UserPromptSubmit",
      "pane": "%42",
      "expect": {
        "stdout": {
          "ok": true,
          "decision": "allow"
        }
      }
    },
    {
      "event": "UserPromptSubmit",
      "pane": "%42",
      "expect": {
        "stdout": {
          "ok": true
        },
        "stdout_path": [
          {
            "path": "hint.message",
            "value": "Remember: use TypeScript strict mode"
          }
        ]
      }
    }
  ]
}
