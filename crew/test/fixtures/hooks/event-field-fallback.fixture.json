{
  "name": "event-field-fallback",
  "description": "Hook event uses 'event' field when 'hook_event_name' is missing",
  "seed": {
    "room": {
      "name": "dev",
      "path": "/tmp/test-crew"
    },
    "agents": [
      {
        "name": "w1",
        "pane": "%42",
        "role": "worker"
      }
    ],
    "goals": [
      {
        "agent": "w1",
        "description": "Use event field"
      }
    ]
  },
  "steps": [
    {
      "event": "__skip__",
      "pane": "%42",
      "payload": {
        "event": "Stop",
        "session_id": "s1"
      },
      "expect": {
        "stdout": {
          "ok": true
        },
        "tmux": [
          {
            "op": "sendKeys",
            "target": "%42",
            "contains": "Goal"
          }
        ]
      }
    }
  ]
}
